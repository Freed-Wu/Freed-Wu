{
  "Lua.codeLens.enable": true,
  "Lua.completion.callSnippet": "Both",
  "Lua.hint.enable": true,
  "Lua.hint.setType": true,
  "cSpell.allowCompoundWords": true,
  "coc.preferences.enableMarkdown": true,
  "coc.source.around.shortcut": "",
  "coc.source.bibtex.shortcut": "",
  "coc.source.buffer.shortcut": "",
  "coc.source.dictionary.shortcut": "",
  "coc.source.emoji.shortcut": "😀",
  "coc.source.file.shortcut": "",
  "coc.source.issues.shortcut": "",
  "coc.source.syntax.shortcut": "󱔁",
  "coc.source.tag.shortcut": "󰓹",
  "coc.source.word.shortcut": "",
  "dash-complete.shortcut": "-",
  "diagnostic-languageserver.filetypes": {
    "bbcode": ["write-good", "alex-text"],
    "c": ["cppcheck"],
    "cpp": ["cppcheck"],
    "cmake": ["cmake-lint", "cmakelint"],
    "elixir": ["mix_credo", "mix_credo_compile"],
    "expect": ["nagelfar"],
    "gitcommit": ["write-good", "alex-text"],
    "html": ["alex-html"],
    "jq": ["jq"],
    "lua": ["luacheck"],
    "mail": ["write-good", "alex-text"],
    "markdown": ["write-good", "alex"],
    "perl": ["perl"],
    "php": ["phpstan", "psalm"],
    "sh": ["bash", "zsh"],
    "systemd": ["systemd-analyze"],
    "text": ["write-good", "alex-text"],
    "tcl": ["nagelfar"],
    "vim": ["vint"],
    "xdc": ["nagelfar"],
    "xsct": ["nagelfar"],
    "yaml": ["yamllint", "actionlint"]
  },
  "diagnostic-languageserver.formatFiletypes": {
    "blade": "blade-formatter",
    "dart": "dartfmt",
    "elixir": "mix_format",
    "fish": "fish_indent",
    "perl": "perltidy",
    "sh": "shfmt",
    "verilog": "iStyle"
  },
  "diagnostic.errorSign": "",
  "diagnostic.format": "%source%code: %message",
  "diagnostic.hintSign": "",
  "diagnostic.infoSign": "",
  "dot-complete.shortcut": ".",
  "git.gitlab.hosts": ["gitlab.com", "gitee.com"],
  "git.showCommitInFloating": true,
  "git.virtualTextPrefix": "",
  "highlight.colors.enable": true,
  "highlight.document.enable": true,
  "html.autoClosingTags": true,
  "just-complete.shortcut": "_",
  "languageserver": {
    "arduino": {
      "command": "arduino-language-server",
      "filetypes": ["arduino"]
    },
    "asm": {
      "command": "asm-lsp",
      "filetypes": ["asm", "nasm"]
    },
    "bash": {
      "command": "termux-language-server",
      "filetypes": ["sh"]
    },
    "bitbake": {
      "command": "bitbake-language-server",
      "filetypes": ["bitbake"]
    },
    "config": {
      "command": "autoconf-language-server",
      "filetypes": ["config"]
    },
    "expect": {
      "command": "expect-language-server",
      "filetypes": ["expect"]
    },
    "hdlChecker": {
      "command": "hdl_checker",
      "args": ["--lsp"],
      "filetypes": ["vhdl", "verilog"]
    },
    "jq": {
      "command": "jq-lsp",
      "filetypes": ["jq"]
    },
    "make": {
      "command": "make-language-server",
      "filetypes": ["make"]
    },
    "mutt": {
      "command": "mutt-language-server",
      "filetypes": ["muttrc"]
    },
    "requirements": {
      "command": "requirements-language-server",
      "filetypes": ["requirements"]
    },
    "sublime-syntax": {
      "command": "sublime-syntax-language-server",
      "filetypes": ["syntax_test"]
    },
    "svls": {
      "command": "svls",
      "filetypes": ["systemverilog"]
    },
    "tmux": {
      "command": "tmux-language-server",
      "filetypes": ["tmux"]
    },
    "xilinx": {
      "command": "xilinx-language-server",
      "filetypes": ["xdc", "xsct"]
    },
    "zathura": {
      "command": "zathura-language-server",
      "filetypes": ["zathurarc"]
    }
  },
  "leetcode.language": "cpp",
  "links.highlight": true,
  "links.tooltip": true,
  "list.insertMappings": {
    "<A-a>": "normal:gg",
    "<A-e>": "normal:G",
    "<A-g>": "do:selectall",
    "<A-j>": "prompt:next",
    "<A-k>": "prompt:previous",
    "<A-n>": "do:previewdown",
    "<A-p>": "do:previewup",
    "<A-v>": "feedkeys:<PageUp>",
    "<C-B>": "prompt:left",
    "<C-D>": "prompt:deletebackward",
    "<C-F>": "prompt:right",
    "<C-G>": "do:toggle",
    "<C-N>": "do:next",
    "<C-P>": "do:previous",
    "<C-Q>": "do:help",
    "<C-V>": "feedkeys:<PageDown>",
    "<C-X>": "do:previewtoggle",
    "<C-Y>": "prompt:paste",
    "<C-k>": "prompt:removetail"
  },
  "list.normalMappings": {
    "<Space>": "feedkeys:<Space>",
    "?": "feedkeys:?",
    "d": "feedkeys:<PageDown>",
    "o": "do:toggle",
    "t": "feedkeys:t",
    "u": "feedkeys:<PageUp>",
    "x": "action:delete"
  },
  "list.source.bibtex.citation": {
    "after": "}",
    "before": "\\cite{"
  },
  "list.source.bibtex.files": ["*.bib", "refs/*.bib"],
  "list.source.files.args": ["--hidden", "--files"],
  "ltex.completionEnabled": true,
  "markdown-preview-enhanced.enableScriptExecution": true,
  "markdown-preview-enhanced.previewTheme": "github-dark.css",
  "perl.p::ls.enable": true,
  "perl.p::ls.disableCache": true,
  "prettier.ignorePath": ".gitignore",
  "pydocstring.enableFileAction": true,
  "python.sortImports.path": "",
  "pyright.testing.provider": "pytest",
  "python.formatting.provider": "none",
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "rime.schemaId": "double_pinyin_mspy",
  "ruff.enableExperimentalFormatter": true,
  "semanticTokens.enable": true,
  "session.directory": "~/.local/share/nvim/session",
  "session.saveOnVimLeave": false,
  "snippets.shortcut": "",
  "snippets.userSnippetsDirectory": "~/.config/nvim/ultisnips",
  "solargraph.autoformat": true,
  "solargraph.diagnostics": true,
  "solargraph.formatting": true,
  "suggest.completionItemKindLabels": {
    "text": "",
    "method": "",
    "function": "󰊕",
    "constructor": "󰒓",
    "field": "",
    "variable": "",
    "class": "",
    "interface": "",
    "module": "󰕳",
    "property": "",
    "unit": "󰑭",
    "value": "",
    "enum": "",
    "keyword": "",
    "snippet": "",
    "color": "",
    "file": "",
    "reference": "",
    "folder": "",
    "enumMember": "",
    "constant": "",
    "struct": "",
    "event": "",
    "operator": "",
    "typeParameter": "",
    "default": ""
  },
  "suggest.invalidInsertCharacters": ["(", "<", "{", "[", "\r", "\n"],
  "suggest.snippetIndicator": "",
  "suggest.triggerAfterInsertEnter": true,
  "tabnine.shortcut": "",
  "tasks.shortcut": "",
  "texlab.chktex.onEdit": true,
  "texlab.chktex.onOpenAndSave": true,
  "texlab.forwardSearch.executable": "zathura",
  "translator.enableHover": true,
  "translator.engines": ["google"],
  "translator.proxy": "socks://127.0.0.1:1080",
  "yaml.format.singleQuote": true,
  "zi.hover": false
}
